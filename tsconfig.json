{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "types": ["bun-types", "@types/webmidi"],
  },
  "include": [
    "src/**/*.ts",
    "scripts/generate-mode-changed-fixtures.ts",
    "scripts/generate-tonic-changed-fixtures.ts",
    "scripts/generate-chord-changed-fixtures.ts",
  ],
}
