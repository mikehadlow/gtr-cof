{
  "name": "gtr-cof",
  "version": "1.0.0",
  "description": "gtr-cof",
  "scripts": {
    "start": "bun run build && bunx serve ./docs",
    "build": "bun run typecheck && bun build ./src/index.ts --outfile ./docs/gtr-cof.js --target=browser --sourcemap=linked && mv ./src/gtr-cof.js ./src/gtr-cof.js.map ./docs/",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src"
  },
  "author": "Mike Hadlow",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.8",
    "@types/d3": "^3.0.0",
    "@types/webmidi": "^2.0.2",
    "d3": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
