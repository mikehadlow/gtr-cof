{
    "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
    "files": {
        "includes": ["src/**/*.ts"]
    },
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noDoubleEquals": "warn",
                "noExplicitAny": "off"
            },
            "correctness": {
                "noUnusedVariables": "warn",
                "noUnusedImports": "warn"
            },
            "nursery": {
                "noFloatingPromises": "error"
            },
            "style": {
                "noParameterAssign": "off",
                "noNonNullAssertion": "off",
                "useBlockStatements": "error"
            }
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
